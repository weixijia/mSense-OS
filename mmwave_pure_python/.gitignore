# External cloned reference repos (large; clone separately if needed)
downloads/

# studio_cli/ is TI's Radar Toolbox tool tree (firmware source, docs, Windows .exe binaries).
# Do NOT redistribute it here — obtain it from the TI Radar Toolbox. Keep ONLY our own
# vomee capture profiles. (The radar firmware already persists on the chip; see UBUNTU_SETUP.md.)
studio_cli/*
!studio_cli/src
studio_cli/src/*
!studio_cli/src/profiles
studio_cli/src/profiles/*
!studio_cli/src/profiles/profile_vomee_256x255_cont.cfg
!studio_cli/src/profiles/profile_vomee_256x255_xwr18xx.cfg

# Large captured data / binary artifacts
ground_truth/*.bin
ground_truth/*.npy
ground_truth/*.png
ground_truth/trace_existing.txt
ground_truth/trace_premerge_old.txt
ground_truth/trace_skeleton2.txt
**/captured_adc_vomee/
